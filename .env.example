# ─────────────────────────────────────────────────────────────
#  KU Budget — Environment Variables
#  Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────

# Server port (Render injects this automatically)
PORT=5000

# JSON Web Token secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# Set to "production" on Render, "development" locally
NODE_ENV=development
