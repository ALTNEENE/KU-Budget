# KU Budget environment variables
# Copy this file to .env for local development.
# In Vercel, add these values in Project Settings > Environment Variables.

# Local backend port
PORT=5000

# Railway MySQL
# Railway exposes MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE,
# and MYSQL_URL. For Vercel, use the public TCP proxy host/port from Railway.
MYSQLHOST=your-railway-public-host.rlwy.net
MYSQLPORT=your_railway_tcp_proxy_port
MYSQLUSER=root
MYSQLPASSWORD=your_railway_mysql_password
MYSQLDATABASE=railway
MYSQL_CHARSET=utf8mb4

# Optional: set to true only if your Railway MySQL connection requires SSL.
MYSQL_SSL=false

# Optional compatibility names. The backend accepts either MYSQL* or DB_*.
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_CHARSET=utf8mb4

# JSON Web Token secret. Use a long random value in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# Seed data
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@karary.edu.sd
SEED_ADMIN_PASSWORD=admin123
SEED_SAMPLE_DATA=true

# Frontend API base. Leave blank on Vercel so the app uses /api.
VITE_API_URL=

NODE_ENV=development
